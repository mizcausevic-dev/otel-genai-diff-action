{
  "name": "otel-genai-diff-action",
  "version": "0.1.0",
  "description": "GitHub Action that retrieves the previous version of an OTel GenAI rollup report via `git show <base.sha>:<report-path>`, diffs it against HEAD using otel-genai-diff, posts the structured diff as a PR comment, and fails the build on breaking cost / token jumps. Fifth and final in the per-protocol diff Action quintet.",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/otel-genai-diff-action"
  },
  "keywords": [
    "github-action",
    "actions",
    "otel",
    "opentelemetry",
    "genai",
    "diff",
    "cost-monitoring",
    "ai-governance",
    "kinetic-gain-suite",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
